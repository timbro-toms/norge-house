# Norge House Production Environment
# Copy to .env on the server: cp .env.production .env

# Public URL (change to https://norgehouse.com when going to prod)
PUBLIC_URL=https://wooden-houses.itlinden.lv

# PostgreSQL
POSTGRES_DB=norgehouse
POSTGRES_USER=norgehouse
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Payload CMS
PAYLOAD_SECRET=CHANGE_ME_32_CHAR_RANDOM_STRING

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@norgehouse.com
RESEND_TO_EMAIL=info@norgehouse.com
