# ── Database ──
POSTGRES_DB=norgehouse
POSTGRES_USER=norgehouse
POSTGRES_PASSWORD=changeme-use-a-strong-password

# ── Payload CMS ──
PAYLOAD_SECRET=your-secret-key-min-32-chars-change-this
NEXT_PUBLIC_SERVER_URL=http://localhost

# ── Next.js Web ──
NEXT_PUBLIC_PAYLOAD_URL=http://cms:3001
NEXT_PUBLIC_SITE_URL=http://localhost
PAYLOAD_PUBLIC_SITE_URL=http://localhost

# ── Email (optional — contact forms) ──
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@norgehouse.com
RESEND_TO_EMAIL=info@norgehouse.com

# ── Domain (production only) ──
DOMAIN=norgehouse.com
